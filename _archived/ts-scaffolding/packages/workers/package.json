{
  "name": "@valinor/workers",
  "version": "2.0.0",
  "description": "Background job processors and queue handlers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/worker.ts",
    "start": "node dist/worker.js",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@valinor/core": "workspace:*",
    "@valinor/shared": "workspace:*",
    "@valinor/agents": "workspace:*",
    "bullmq": "^4.15.0",
    "ioredis": "^5.3.0",
    "cron": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./analysis": {
      "types": "./dist/workers/analysis.d.ts",
      "default": "./dist/workers/analysis.js"
    },
    "./report": {
      "types": "./dist/workers/report.d.ts",
      "default": "./dist/workers/report.js"
    },
    "./notification": {
      "types": "./dist/workers/notification.d.ts",
      "default": "./dist/workers/notification.js"
    }
  }
}