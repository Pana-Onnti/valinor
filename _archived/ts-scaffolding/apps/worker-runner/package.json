{
  "name": "@valinor/worker-runner",
  "version": "2.0.0",
  "description": "GitHub Actions worker runner for analysis processing",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@valinor/core": "workspace:*",
    "@valinor/shared": "workspace:*",
    "@valinor/agents": "workspace:*",
    "@valinor/workers": "workspace:*",
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  }
}