{
  "name": "@valinor/api-gateway",
  "version": "2.0.0",
  "description": "Cloudflare Workers API Gateway for Valinor SaaS",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .wrangler dist"
  },
  "dependencies": {
    "@valinor/shared": "workspace:*",
    "hono": "^3.12.0",
    "@hono/zod-validator": "^0.2.0",
    "zod": "^3.22.0",
    "@supabase/supabase-js": "^2.38.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@cloudflare/workers-types": "^4.20231218.0",
    "typescript": "^5.3.0",
    "wrangler": "^3.22.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  }
}