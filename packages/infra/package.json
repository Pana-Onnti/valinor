{
  "name": "@valinor/infra",
  "version": "2.0.0",
  "description": "Infrastructure as Code and deployment configurations",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "deploy:staging": "pulumi up --stack staging",
    "deploy:production": "pulumi up --stack production",
    "preview:staging": "pulumi preview --stack staging",
    "preview:production": "pulumi preview --stack production",
    "destroy:staging": "pulumi destroy --stack staging",
    "destroy:production": "pulumi destroy --stack production",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pulumi/pulumi": "^3.96.0",
    "@pulumi/cloudflare": "^5.15.0",
    "@pulumi/github": "^5.25.0",
    "@pulumi/random": "^4.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  }
}