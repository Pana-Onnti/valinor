# Valinor SaaS - Staging Environment Configuration
# Copy this to staging.env and fill in actual values

# Environment
NODE_ENV=staging
ENVIRONMENT=staging

# Database - Supabase
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Claude AI
ANTHROPIC_API_KEY=sk-ant-api03-...

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_characters_for_staging

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Cloudflare
CLOUDFLARE_API_TOKEN=your_cf_api_token
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id

# Stripe (Test Mode)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (Upstash)
REDIS_URL=redis://default:password@global-touching-dog-12345.upstash.io:6379

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@staging.valinor.com

# Monitoring
SENTRY_DSN=https://...@sentry.io/...

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_WEBHOOKS=true

# Rate Limiting
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_ENTERPRISE=1000

# Queue Configuration
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT=600000  # 10 minutes

# File Storage
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=sql,csv,xlsx

# URLs
FRONTEND_URL=https://valinor-staging.vercel.app
DASHBOARD_URL=https://dashboard-staging.vercel.app
API_URL=https://valinor-api-staging.workers.dev
WEBHOOK_URL=https://valinor-api-staging.workers.dev