# Valinor SaaS - Production Environment Configuration
# Copy this to production.env and fill in actual values

# Environment
NODE_ENV=production
ENVIRONMENT=production

# Database - Supabase Pro
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Claude AI - Production
ANTHROPIC_API_KEY=sk-ant-api03-...

# JWT - Strong production secret
JWT_SECRET=super_secure_jwt_secret_64_characters_minimum_production_grade

# GitHub - Production
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=production_webhook_secret

# Cloudflare - Production account
CLOUDFLARE_API_TOKEN=your_production_cf_api_token
CLOUDFLARE_ACCOUNT_ID=your_production_cf_account_id

# Stripe - Live Mode
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis - Upstash Production
REDIS_URL=redis://default:password@global-production-db-12345.upstash.io:6379

# Email - Resend Production
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@valinor.com

# Monitoring - Full stack
SENTRY_DSN=https://...@sentry.io/...
DATADOG_API_KEY=your_datadog_api_key

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_WEBHOOKS=true
ENABLE_RATE_LIMITING=true

# Rate Limiting - Production tiers
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_ENTERPRISE=1000

# Queue Configuration - Production scale
MAX_CONCURRENT_JOBS=20
JOB_TIMEOUT=1800000  # 30 minutes for large databases

# File Storage - Production limits
MAX_FILE_SIZE=52428800  # 50MB
ALLOWED_FILE_TYPES=sql,csv,xlsx,json

# Security
CORS_ORIGINS=https://valinor.com,https://dashboard.valinor.com
HELMET_CONFIG=true
CSRF_PROTECTION=true

# URLs - Production domains
FRONTEND_URL=https://valinor.com
DASHBOARD_URL=https://dashboard.valinor.com
API_URL=https://api.valinor.com
WEBHOOK_URL=https://api.valinor.com

# SSL/TLS
SSL_REDIRECT=true
HSTS_MAX_AGE=31536000

# Backup & Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Performance
CACHE_TTL=3600  # 1 hour
CDN_CACHE_TTL=86400  # 24 hours