# Worker Dockerfile for background tasks
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libpq-dev \
    openssh-client \
    liblapack-dev \
    libblas-dev \
    gfortran \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir setuptools && pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY worker/ /app/worker/
COPY shared/ /app/shared/
COPY core/ /app/core/

# Create necessary directories
RUN mkdir -p /app/ssh_keys /app/logs /app/temp

# Set Python path
ENV PYTHONPATH=/app:$PYTHONPATH

# Run as non-root user
RUN useradd -m -u 1000 valinor && chown -R valinor:valinor /app
USER valinor

# Default command
CMD ["celery", "-A", "worker.tasks", "worker", "--loglevel=info"]