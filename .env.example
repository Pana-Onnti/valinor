# Valinor SaaS Environment Configuration
# Copy this file to .env and fill in your values

# ═══ API Configuration ═══
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ═══ Redis Configuration ═══
REDIS_URL=redis://localhost:6379/0

# ═══ Celery Configuration ═══
CELERY_BROKER=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ═══ Metadata Storage (Supabase) ═══
# Leave empty to use local storage fallback
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ═══ Claude SDK Configuration ═══
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_SDK_API_KEY=your_claude_sdk_key_here

# ═══ Security ═══
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here

# ═══ Monitoring (Optional) ═══
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# === Railway (auto-injected in Railway, no setear manualmente) ===
# DATABASE_URL=
# REDIS_URL=

# === Agent Observability (VAL-29) ===
# LMNR_API_KEY=your_laminar_api_key_here
# When set, all swarm agents are traced in lmnr (laminar.dev) with spans per step.
# Leave empty to disable lmnr and use structured log tracing only.
PROMETHEUS_PORT=9090

# === Token Tracking & KV-Cache (VAL-31) ===
# Set to true to enable Anthropic KV-cache (prompt caching) and Prometheus token metrics.
# Cache reduces cost ~40% on repeated system prompts.
ENABLE_TOKEN_TRACKING=true

# ═══ Environment ═══
# Values: development | staging | production
APP_ENV=development

# ═══ Database Drivers ═══
# Uncomment and configure as needed
# POSTGRES_DRIVER=psycopg2
# MYSQL_DRIVER=pymysql
# MSSQL_DRIVER=pyodbc

# ═══ Logging ═══
LOG_LEVEL=INFO
STRUCTLOG_PRETTY=true

# ═══ SSH Configuration ═══
# Default SSH key paths (can be overridden per request)
SSH_DEFAULT_KEY_PATH=/home/user/.ssh/id_rsa
SSH_KNOWN_HOSTS_PATH=/home/user/.ssh/known_hosts

# ═══ File Storage ═══
TEMP_OUTPUT_DIR=/tmp/valinor_output
METADATA_STORAGE_DIR=/tmp/valinor_metadata

# ═══ Security Settings ═══
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=3600
CLEANUP_JOBS_AFTER_HOURS=24